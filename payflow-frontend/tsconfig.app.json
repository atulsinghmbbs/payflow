{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": ["node"]
  },
  "files": [
    "src/main.ts",
    "src/main.server.ts",
    "src/server.ts"
  ],
  "include": [
    "src/**/*.d.ts",
    "src/app/**/*.ts",
    "src/components/**/*.ts",
    "src/services/**/*.ts",
    "src/interceptors/**/*.ts",
    "src/environments/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
